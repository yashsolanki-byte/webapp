# Copy to ".env" and fill in (never commit .env).
# Passwords for NPF publisher logins — used by manual scrape, batch scrape, and script_scraper.

NPF_PASSWORD_CENTRAL=
NPF_PASSWORD_SANJAY=
NPF_PASSWORD_AMIT=

# Optional: ms to wait after Campaign Detailed View loads so institute dropdown can populate (default 2500).
# NPF_DETAILED_VIEW_SETTLE_MS=3500

# Manual scrape (web app): max "Primary Leads" count before aborting and asking for a smaller date range (default 100000). Set to 0 to disable.
# NPF_MANUAL_SCRAPE_MAX_LEADS=100000

# Manual scrape jobs (Redis + RQ): start Redis, then run one or more workers from npf-scraper-webapp:
#   rq worker -u redis://127.0.0.1:6379/0 manual_scrape
# REDIS_URL=redis://127.0.0.1:6379/0
# MANUAL_SCRAPE_RQ_QUEUE=manual_scrape
# MANUAL_SCRAPE_JOB_TIMEOUT_SEC=1800
# MANUAL_SCRAPE_TRANSIENT_RETRIES=3
# MANUAL_SCRAPE_RQ_TIMEOUT_SEC=1860
# Manual scrape RQ job: 1 = headless Chromium (default). 0 = visible browser (debug on a PC with a display).
# MANUAL_SCRAPE_HEADLESS=0
