# Copy to ".env" and fill in (never commit .env).
# REQUIRED: NPF passwords + REDIS_URL for manual scrape queue.

# ---------- Required credentials ----------
NPF_PASSWORD_CENTRAL=
NPF_PASSWORD_SANJAY=
NPF_PASSWORD_AMIT=

# ---------- Required for manual scrape queue (Redis + RQ) ----------
# Local Redis without password:
REDIS_URL=redis://127.0.0.1:6379/0
# If Redis requires auth, use:
# REDIS_URL=redis://:YOUR_REDIS_PASSWORD@127.0.0.1:6379/0
MANUAL_SCRAPE_RQ_QUEUE=manual_scrape
# 1 = headless Chromium (recommended/server), 0 = visible browser (desktop debugging).
MANUAL_SCRAPE_HEADLESS=1

# ---------- Optional tuning ----------
# Manual scrape abort threshold on "Primary Leads" count (default 100000). Set 0 to disable.
NPF_MANUAL_SCRAPE_MAX_LEADS=100000
# Wait after Campaign Detailed View load so institute dropdown populates (default 2500).
# NPF_DETAILED_VIEW_SETTLE_MS=3500
# Worker/job timing controls:
# MANUAL_SCRAPE_JOB_TIMEOUT_SEC=1800
# MANUAL_SCRAPE_TRANSIENT_RETRIES=3
# MANUAL_SCRAPE_RQ_TIMEOUT_SEC=1860

# ---------- Optional Drive uploader settings ----------
# FEEDBACK_READY_ROOT_ID=
DRIVE_SOURCE_DATA_FOLDER_NAME=scraped data
FEEDBACK_READY_FOLDER_NAME=Feedback Uploader Ready
